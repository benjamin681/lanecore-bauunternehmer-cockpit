# B+4.3.2b-1: docker-compose.yml Environment-Template.
#
# Usage:
#   cp .env.example .env
#   # Editiere .env (SECRET_KEY, ANTHROPIC_API_KEY zwingend)
#   docker compose up --build
#
# HINWEIS: Diese .env gehoert zu docker-compose und ersetzt NICHT die
# bestehende lv-preisrechner/backend/.env fuer lokale Dev-Laufzeit.

# -----------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------
POSTGRES_DB=lvpreisrechner
POSTGRES_USER=lvpuser
# In Production: starkes Passwort (32+ Zeichen, zufaellig):
#   openssl rand -base64 24
POSTGRES_PASSWORD=change-me-in-prod

# -----------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------
# Zwingend in Production setzen:
#   openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-32-char-hex-string

# Zwingend: Anthropic-Key aus console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# CORS: JSON-Array-String (pydantic-settings erwartet JSON-Listen).
# Fuer lokalen Test: Frontend laeuft auf localhost:3000.
# Fuer Production: Liste mit der echten Frontend-Domain.
CORS_ORIGINS=["http://localhost:3000"]

# Claude-Modelle. Defaults sind passend, nur ueberschreiben wenn noetig.
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_FALLBACK=claude-opus-4-6

# APP_ENV: production oder development
APP_ENV=production

# -----------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------
# NEXT_PUBLIC_BACKEND_URL wird im Browser verwendet (direkte Calls).
# Fuer lokalen Compose-Test: Backend ist ueber Host-Port 8000 erreichbar.
# Fuer Production mit Caddy: https://api.deine-domain.de
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# BACKEND_URL wird serverseitig vom Frontend-Container verwendet
# (next.config.js rewrites). Im Compose-Netzwerk ist der Backend-
# Service via Hostname "backend" erreichbar.
BACKEND_URL=http://backend:8000
