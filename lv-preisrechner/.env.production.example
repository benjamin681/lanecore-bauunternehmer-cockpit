# B+4.3.2c-1: Production-.env-Template fuer Hetzner-Deployment.
#
# Usage (auf dem Server, als appuser):
#   cd /home/appuser/lvp/lv-preisrechner
#   cp .env.production.example .env
#   nano .env           # Alle Pflichtfelder mit echten Werten fuellen
#   chmod 600 .env
#
# NIEMALS echte Secrets in dieses Template einchecken — nur Platzhalter.
# Die .env selbst ist im .dockerignore/.gitignore und bleibt nur auf
# dem Server.

# =======================================================================
# Postgres
# =======================================================================
POSTGRES_DB=lvpreisrechner
POSTGRES_USER=lvpuser
# Generiere mit:  openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_ME_WITH_openssl_rand_-base64_24

# =======================================================================
# Backend
# =======================================================================
# Generiere mit:  openssl rand -hex 32
# SECRET_KEY signiert JWT-Tokens — bei Wechsel werden alle Sessions ungueltig.
SECRET_KEY=REPLACE_ME_WITH_openssl_rand_-hex_32

# Aus console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# CORS: JSON-Array-String. Muss alle Frontend-Origins enthalten, die mit
# dem Backend reden duerfen.
#
# TLS-Workflow: solange Caddy noch kein Zertifikat geholt hat (DNS nicht
# propagiert, Caddy nicht gestartet), ist der Stack nicht ueber Domain
# erreichbar. Sobald DNS + Caddy stehen: auf https-Domain umstellen und
# Frontend neu bauen (siehe docs/b432c_hetzner_runbook.md §13).
#
# Beispiel (auskommentiert — auf eigene Domain anpassen):
#   CORS_ORIGINS=["https://app.deine-domain.de"]
CORS_ORIGINS=["https://REPLACE_ME_FRONTEND_DOMAIN"]

CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_FALLBACK=claude-opus-4-6

APP_ENV=production

# =======================================================================
# Frontend
# =======================================================================
# NEXT_PUBLIC_BACKEND_URL wird im Browser verwendet (direkte API-Calls vom
# Client). Caddy proxyt /api/* auf denselben Host wie das Frontend — also
# ist das meistens die gleiche Domain wie CORS_ORIGINS, NICHT eine separate
# api.*-Subdomain. Erst nach DNS+TLS auf die echte Domain setzen und das
# Frontend neu bauen.
#
# Beispiel (auskommentiert):
#   NEXT_PUBLIC_BACKEND_URL=https://app.deine-domain.de
NEXT_PUBLIC_BACKEND_URL=https://REPLACE_ME_FRONTEND_DOMAIN

# BACKEND_URL wird server-seitig vom Frontend-Container verwendet
# (next.config.js rewrites). Im Compose-Netzwerk ist der Backend-Service
# via Hostname "backend" erreichbar — darum hier intern bleiben lassen.
BACKEND_URL=http://backend:8000
