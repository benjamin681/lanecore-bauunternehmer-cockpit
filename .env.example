# =============================
# LaneCore AI — Environment Variables
# Kopiere diese Datei als .env und fülle die Werte aus.
# =============================

# --- App ---
APP_ENV=development
DEBUG=true

# --- Claude API (PFLICHT) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lanecore

# --- S3-kompatibel (Cloudflare R2 / AWS S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=lanecore-uploads

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Limits ---
MAX_PDF_SIZE_MB=50
MAX_PAGES_PER_PLAN=200
